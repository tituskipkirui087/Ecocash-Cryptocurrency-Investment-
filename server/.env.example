# Development values
PORT=5000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url.supabase.co
JWT_SECRET=replace_with_a_strong_production_secret

# Production values (set in Render dashboard)
FRONTEND_URL=https://ecocash-investment-copmanyzm.vercel.app
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_telegram_admin_chat_id
# Generate a long random value. It must also be supplied as Telegram's
# `secret_token` when registering the webhook.
TELEGRAM_WEBHOOK_SECRET=replace_with_a_long_random_webhook_secret
# Used by existing authenticated API routes; do not use a source-controlled default.
BOT_SECRET=replace_with_a_strong_api_secret
TRC20_WALLET_ADDRESS=
ECOASH_NUMBER=0712345678
NODE_ENV=development
