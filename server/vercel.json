{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/investments/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/deposits/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/admin/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/sse/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    }
  ]
}